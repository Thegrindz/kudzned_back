# Application
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_NAME=kudzned

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=24h

# Bitcoin
BTC_NETWORK=testnet
BTC_API_KEY=your_btc_api_key
BTC_WEBHOOK_SECRET=your_webhook_secret

# Email Service
EMAIL_API_KEY=your_email_api_key
FROM_EMAIL=noreply@kudzned.com

# KYC Service
KYC_API_KEY=your_kyc_api_key
KYC_API_SECRET=your_kyc_secret

# File Storage
STORAGE_BUCKET=kudzned-files
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key